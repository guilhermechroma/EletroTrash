// Atributos do item caindo (dificuldade, velocidade, margem da parede)
difficulty = 0;
item_speed = 4;
margin = 100;

// Contador para o alarme 0 repetir ou ir para o próximo
counter = 0

// "Spawna" um item a cada 60 frames
alarm[0] = 60;

// Randomiza os resultados toda vez que esse objeto é criado (sempre ao iniciar o jogo)
randomise()